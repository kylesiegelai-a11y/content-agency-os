{
  "name": "content-agency-os",
  "version": "1.0.0",
  "description": "Production-ready Content Agency OS with job orchestration, scheduling, and queue management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "MOCK_MODE=true nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "dashboard:install": "npm --prefix dashboard install",
    "dashboard:build": "npm --prefix dashboard run build",
    "build": "npm run dashboard:install && npm run dashboard:build",
    "migrate:sqlite": "node scripts/migrateToSqlite.js",
    "dev:sqlite": "USE_SQLITE=true MOCK_MODE=true nodemon server.js",
    "preflight": "bash scripts/preflight.sh",
    "kill-switch": "curl -X POST http://localhost:3001/api/settings/kill-switch -H 'Authorization: Bearer mock-jwt-token-for-development' -H 'Content-Type: application/json' -d '{\"enabled\": true}'"
  },
  "keywords": [
    "content-agency",
    "job-orchestration",
    "queue-management",
    "scheduling",
    "bull",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "cron": "^3.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "marked": "^4.3.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.18.0",
    "redis": "^4.6.12",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
