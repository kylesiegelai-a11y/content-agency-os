# Content Agency OS Environment Configuration

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development

# Enable mock mode (in-memory queues, no Redis required)
# Set to 'true' for development/testing, 'false' for production
MOCK_MODE=true

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT secret key for token signing
# Change this to a secure random string in production
JWT_SECRET=dev-secret-key-change-in-production

# Admin password for login
# Change this to a secure password in production
ADMIN_PASSWORD=admin123

# ============================================================================
# REDIS CONFIGURATION (only needed if MOCK_MODE=false)
# ============================================================================

# Full Redis URL (takes precedence if set)
# REDIS_URL=redis://localhost:6379

# Or use individual Redis parameters
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis database number (optional, default: 0)
# REDIS_DB=0

# Redis password (optional)
# REDIS_PASSWORD=your-redis-password

# ============================================================================
# DATABASE
# ============================================================================

# Set to 'true' to use SQLite instead of JSON file storage
# Run 'npm run migrate:sqlite' first to migrate existing data
# USE_SQLITE=true

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# Maximum number of retries for failed jobs
MAX_RETRIES=3

# Activity log file location (relative to project root)
ACTIVITY_LOG_FILE=data/activity.json

# ============================================================================
# LOGGING
# ============================================================================

# Morgan logging format: 'combined', 'common', 'dev', 'short', 'tiny'
MORGAN_FORMAT=combined

# ============================================================================
# DASHBOARD
# ============================================================================

# Dashboard build directory
DASHBOARD_PATH=./dashboard

# ============================================================================
# EXAMPLE PRODUCTION CONFIGURATION
# ============================================================================

# ============================================================================
# JWT SECRET ROTATION
# ============================================================================

# When rotating secrets, set the old secret here temporarily so existing
# tokens continue to work during the transition window.
# JWT_SECRET_PREVIOUS=your-old-jwt-secret

# ============================================================================
# ALERTING
# ============================================================================

# Email address for critical system alerts (job failures, threshold breaches)
# ALERT_EMAIL=admin@yourdomain.com

# ============================================================================
# EXAMPLE PRODUCTION CONFIGURATION
# ============================================================================

# For production, uncomment and configure:
# MOCK_MODE=false
# NODE_ENV=production
# PORT=3001
# JWT_SECRET=your-super-secure-random-key-here
# JWT_SECRET_PREVIOUS=
# ADMIN_PASSWORD=your-very-secure-password
# ALERT_EMAIL=admin@yourdomain.com
# REDIS_URL=redis://production-redis-instance:6379
# MAX_RETRIES=5
